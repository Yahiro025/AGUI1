# TripBuddy backend env. The agent picks a model based on the FIRST variable
# that is set, in this order:
#   1. TRIPBUDDY_MODEL (explicit, e.g. "test", "openai:gpt-4o-mini", ...)
#   2. GOOGLE_API_KEY or GEMINI_API_KEY  → google-gla:gemini-2.0-flash (free tier)
#   3. GROQ_API_KEY                      → groq:llama-3.3-70b-versatile (free tier)
#   4. OPENROUTER_API_KEY                → openrouter:meta-llama/llama-3.1-8b-instruct:free
#   5. OPENAI_API_KEY                    → openai:gpt-4o-mini (paid)
#   6. *nothing*                         → Pydantic AI TestModel (offline, $0)

# Example: paid-but-cheap OpenAI
# OPENAI_API_KEY=sk-...

# Example: Google Gemini free tier (https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=AIza...

# Example: Groq free tier (https://console.groq.com/keys)
# GROQ_API_KEY=gsk_...

# Example: OpenRouter free models (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-...

# Force the offline scripted model (no key, deterministic):
# TRIPBUDDY_MODEL=test

# Override the default OpenAI model:
# TRIPBUDDY_MODEL=openai:gpt-4o-mini

# --- Production ---

# Comma-separated list of frontend origins allowed to call /agent.
# Example for a Vercel deployment:
#   ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
# If unset, the backend logs a warning and falls back to allow-all (`*`).
# ALLOWED_ORIGINS=https://your-app.vercel.app

